rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isSelf(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // users コレクション
    match /users/{uid} {
      allow read: if isSelf(uid) || isAdmin();
      allow create, update: if isSelf(uid);  // delete は禁止
      allow update: if isAdmin();
    }

    // attendance_records コレクション
    // 書き込みはサーバー（Admin SDK）またはadminのみ。クライアントから直接改ざん不可
    match /attendance_records/{recordId} {
      allow read: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    // alert_logs コレクション
    match /alert_logs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
